{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "bash .github/hooks/scripts/load-migration-state.sh",
        "windows": "pwsh -ExecutionPolicy Bypass -File .github/hooks/scripts/load-migration-state.ps1",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "bash .github/hooks/scripts/update-status-report.sh",
        "windows": "pwsh -ExecutionPolicy Bypass -File .github/hooks/scripts/update-status-report.ps1",
        "timeout": 15
      }
    ]
  }
}
