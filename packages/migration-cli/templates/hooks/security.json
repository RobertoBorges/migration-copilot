{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "bash .github/hooks/scripts/block-secrets.sh",
        "windows": "pwsh -ExecutionPolicy Bypass -File .github/hooks/scripts/block-secrets.ps1",
        "timeout": 10
      },
      {
        "type": "command",
        "command": "bash .github/hooks/scripts/block-dangerous-commands.sh",
        "windows": "pwsh -ExecutionPolicy Bypass -File .github/hooks/scripts/block-dangerous-commands.ps1",
        "timeout": 10
      }
    ]
  }
}
